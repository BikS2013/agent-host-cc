{
  "name": "agent-host-cc",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone TypeScript service that packages the Anthropic Claude Code agent inside a container and exposes it via OpenAI-compatible Chat Completions and Responses APIs.",
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "image:build": "./scripts/build.sh",
    "image:build:docker": "./scripts/build-docker.sh",
    "image:build:apple": "./scripts/build-apple-container.sh",
    "image:run": "./scripts/run.sh",
    "image:run:docker": "./scripts/run-docker.sh",
    "image:run:apple": "./scripts/run-apple-container.sh",
    "image:stop": "./scripts/stop.sh",
    "image:stop:docker": "./scripts/stop-docker.sh",
    "image:stop:apple": "./scripts/stop-apple-container.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.138",
    "fastify": "^5.0.0",
    "undici": "^6.0.0",
    "pino": "^9.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@anthropic-ai/sdk": "^0.91.1"
  }
}
