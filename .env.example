# =============================================================================
# agent-host-cc — environment template
# =============================================================================
# Copy this file to `.env` and fill in the placeholders before running the
# container. The service reads every value below from `process.env` at startup;
# the `.env` file is consumed by Docker / Apple container via `--env-file`,
# NOT by the service itself.
#
# Required variables have NO default — missing them raises ConfigurationError
# at startup and the process exits with code 78.
#
# See docs/design/configuration-guide.md for the full reference.
# =============================================================================


# -----------------------------------------------------------------------------
# Required-always
# -----------------------------------------------------------------------------

# REQUIRED — Bearer token clients must present in `Authorization: Bearer ...`.
# Generate with:  openssl rand -hex 32
AGENT_HOST_API_KEY=replace-me

# REQUIRED — Comma-separated list of model IDs to expose via /v1/models and
# accept on chat completions and responses.
MODEL_IDS=claude-sonnet-4-6,claude-haiku-4-5,claude-opus-4-7


# -----------------------------------------------------------------------------
# Provider — Anthropic public (default path)
# -----------------------------------------------------------------------------

# REQUIRED when CLAUDE_CODE_USE_FOUNDRY != "1".
# Get from: https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=<paste-token-here>

# Optional — ISO-8601 expiry / rotation reminder for ANTHROPIC_API_KEY.
# Behavior: WARN if within 30 days, ERROR if past, INFO otherwise.
# ANTHROPIC_API_KEY_EXPIRES_AT=2026-12-31


# -----------------------------------------------------------------------------
# Provider — Azure AI Foundry (opt-in)
# -----------------------------------------------------------------------------
# Set CLAUDE_CODE_USE_FOUNDRY=1 to opt in. When set, ALL THREE Foundry
# variables below MUST resolve together; partial configuration → exit 78.

# Optional — set to "1" to route via Azure AI Foundry instead of api.anthropic.com.
# CLAUDE_CODE_USE_FOUNDRY=1

# REQUIRED when CLAUDE_CODE_USE_FOUNDRY=1.
# Get from: Azure Portal → AI Foundry resource → Keys
# ANTHROPIC_FOUNDRY_API_KEY=<paste-foundry-key>

# REQUIRED when CLAUDE_CODE_USE_FOUNDRY=1.
# The AI Foundry resource name; the SDK builds the endpoint URL from this.
# ANTHROPIC_FOUNDRY_RESOURCE=<your-foundry-resource>

# Optional — ISO-8601 expiry / rotation reminder for ANTHROPIC_FOUNDRY_API_KEY.
# ANTHROPIC_FOUNDRY_API_KEY_EXPIRES_AT=2026-12-31


# -----------------------------------------------------------------------------
# Files API backend (OPTIONAL — only needed for `files[]` request extension)
# -----------------------------------------------------------------------------
# Leave both BASE_URL and KEY unset to disable files[] handling entirely.
# When unset, the service starts cleanly and silently drops any incoming
# files[] entries. To enable, set BOTH variables together — partial config
# (only one of the two) is rejected at startup with ConfigurationError.

# Optional — Base URL of the upstream files API. Common case: an Open WebUI
# deployment reachable from the container.
# Docker Desktop:        http://host.docker.internal:3080
# Linux default bridge:  http://172.17.0.1:3080
# Apple container:       http://192.168.64.1:3080
# FILES_API_BASE_URL=http://host.docker.internal:3080

# Optional — Bearer token forwarded to the upstream files API.
# For Open WebUI: Profile → Account → API Keys → Generate.
# FILES_API_KEY=<paste-token-here>

# Optional — Path template appended to FILES_API_BASE_URL. Must contain {id}
# exactly once; the service replaces {id} with the URL-encoded file id.
# Default: /api/v1/files/{id}/content
# FILES_API_PATH_TEMPLATE=/api/v1/files/{id}/content

# Optional — ISO-8601 expiry / rotation reminder for FILES_API_KEY.
# FILES_API_KEY_EXPIRES_AT=2026-12-31


# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------

# Optional — IP Fastify binds to.       Default: 0.0.0.0
# LISTEN_HOST=0.0.0.0

# Optional — TCP port Fastify listens on. Default: 8000
# LISTEN_PORT=8000

# Optional — Maximum request body size in bytes (413 returned past this).
# Default: 67108864 (64 MB) — sized for base64-encoded image data URLs.
# BODY_LIMIT_BYTES=67108864


# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------

# Optional — Root directory for per-chat workspaces.
# Default: /workspace (silent-default exception #1; matches the Dockerfile).
# WORKSPACE_DIR=/workspace

# Optional — Per-chat byte cap (413 payload_too_large past this).
# Default: 209715200 (200 MB)
# WORKSPACE_MAX_BYTES_PER_CHAT=209715200

# Optional — Inline-vs-disk threshold for image attachments.
# Default: 20971520 (20 MB)
# MAX_INLINE_IMAGE_BYTES=20971520

# Optional — Per-URL response-size cap for remote / files-API fetches.
# Default: 52428800 (50 MB)
# MAX_REMOTE_FETCH_BYTES=52428800

# Optional — Maximum number of in-message URLs auto-fetched per request.
# Default: 5  (set to 0 to disable in-message URL fetching)
# MAX_URL_FETCHES_PER_TURN=5

# Optional — Per-URL fetch timeout (ms).  Default: 30000
# URL_FETCH_TIMEOUT_MS=30000


# -----------------------------------------------------------------------------
# Agent
# -----------------------------------------------------------------------------

# Optional — Per-turn agent execution timeout (ms). 504 returned past this.
# Default: 300000 (5 minutes)
# AGENT_TIMEOUT_MS=300000

# Optional — SDK maxTurns cost guardrail. Default: 20
# AGENT_MAX_TURNS=20

# Optional — Prefix stripped from inbound `model` field before validation.
# Default: cc.   (empty string disables stripping)
# MODEL_PREFIX=cc.

# Optional — Responses API tool_use rendering.
# Default: text   (only "text" is supported in v1; "item" → exit 78)
# RESPONSES_TOOL_USE_RENDERING=text


# -----------------------------------------------------------------------------
# Auth expiry
# -----------------------------------------------------------------------------

# Optional — ISO-8601 expiry / rotation reminder for AGENT_HOST_API_KEY.
# AGENT_HOST_API_KEY_EXPIRES_AT=2026-12-31


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Optional — Pino log level: fatal | error | warn | info | debug | trace
# Default: info
# LOG_LEVEL=info
