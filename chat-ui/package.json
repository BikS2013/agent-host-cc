{
  "name": "agent-host-cc-chat-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal multi-backend chat UI sub-application for agent-host-cc.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,green \"vite\" \"CHAT_UI_PORT=5174 tsx watch server/index.ts\"",
    "dev:server": "CHAT_UI_PORT=5174 tsx watch server/index.ts",
    "dev:ui": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@preact/signals": "^2.0.0",
    "fastify": "^5.2.0",
    "pino": "^10.0.0",
    "undici": "^8.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.1",
    "@types/node": "^25.0.0",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "preact": "^10.25.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
